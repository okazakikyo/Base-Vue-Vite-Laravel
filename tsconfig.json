{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "node",
        "strict": true,
        "jsx": "preserve",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "lib": ["ESNext", "DOM"],
        "baseUrl": "./",
        "paths": {
            "@/*": ["resources/js/*"],
            "@/views/*": ["resources/js/views/*"],
            "@/constants/*": ["resources/js/shared/constants/*"],
            "@/enums/*": ["resources/js/shared/enums/*"],
            "@/interfaces/": ["resources/js/shared/interfaces/*"],
            "@/types/*": ["resources/js/shared/types/*"],
            "@/stores/*": ["resources/js/stores/*"],
            "@/utils/*": ["resources/js/utils/*"]
        }
    },
    "include": [
        "resources/js/**/*",
        "resources/js/env.d.ts",
        "node_modules/pinia/**/*"
    ],
    "exclude": ["node_modules"]
}
